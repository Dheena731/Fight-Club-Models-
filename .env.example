# Copy to .env and fill in. NEVER commit .env.
# Server
PORT=8787
CLIENT_ORIGIN=http://localhost:5173

# Provider API keys (server-side only — never exposed to the client)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...

# Battle limits (cost guardrails)
MAX_ROUNDS=5
MAX_TOKENS_PER_TURN=150
