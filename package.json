{
  "name": "ai-battle-arena",
  "version": "0.1.0",
  "private": true,
  "description": "A game-feel arena where AI models battle in Roast / Injection / Impersonation modes.",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "npm --prefix client run dev",
    "ping": "node server/scripts/ping.js",
    "battle": "node server/scripts/battle-cli.js",
    "install:all": "npm install && npm --prefix client install"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.65.0",
    "@google/generative-ai": "^0.21.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "impeccable": "^2.3.2",
    "openai": "^4.77.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
